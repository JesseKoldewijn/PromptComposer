{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Prompt Composer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:default",
    "wdio:default",
    "wdio-webdriver:default"
  ]
}
